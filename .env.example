# Copy this file to .env and fill in the values for local development.
#   cp .env.example .env
#
# NEVER commit .env — it is gitignored.
# Variables prefixed VITE_ are embedded into the browser bundle at build time.
# Variables WITHOUT the prefix are only available in Node/Vite config — not in browser code.

# ── App ───────────────────────────────────────────────────────────────────────
# Display name used across the UI (Nav brand, page title, footer copyright).
VITE_APP_NAME=My Project

# Production URL (no trailing slash) — used for og:image and sitemap.
# Set this in your Netlify environment variables once you have a custom domain.
# VITE_APP_URL=https://example.com

# ── Build metadata ────────────────────────────────────────────────────────────
# These are injected automatically by GitHub Actions via the CI workflow.
# You do NOT need to set them manually — leave them commented out locally.
# Vite falls back to sensible defaults (branch=local, commit=dev, env=development).
#
# VITE_BRANCH=local          # git branch name
# VITE_COMMIT=dev            # short commit SHA (7 chars)
# VITE_BUILD_TIME=           # ISO 8601 timestamp, e.g. 2026-03-22T14:00:00Z
# VITE_ENV=development       # one of: development | preview | production

# ── Cookie consent (GDPR) ────────────────────────────────────────────────────
# Set to 'true' to show the cookie consent banner.
# Disabled by default — enable before going live if you use analytics,
# tracking pixels, or any non-essential cookies.
# VITE_COOKIE_CONSENT=false

# ── Add your own variables below ─────────────────────────────────────────────
# Example:
# VITE_API_URL=https://api.example.com
# VITE_GOOGLE_MAPS_KEY=your-key-here
